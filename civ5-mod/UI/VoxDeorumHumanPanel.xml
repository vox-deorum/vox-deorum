<?xml version="1.0" encoding="utf-8"?>
<!--
  Vox Deorum human-control decision panel — stage 7 (full Flavor-mode parity),
  building on stage 5's trigger-button + hidable-dialog model and stage 6's
  in-panel option list.

  The same-named VoxDeorumHumanPanel.lua auto-binds to this context. The whole
  context is hidden on load. When the strategist fires
  LuaEvents.VoxDeorumHumanDecision(playerID, turn, options) the corner widget's
  trigger button appears in the bottom-right action slot — standing in for the
  native "PLEASE WAIT" button — instead of the dialog popping up. `options` is the
  Flavor-mode OptionsReport delivered as a Lua table (the DLL converts it from the
  JSON the bridge carried), so the panel reads its fields directly with no JSON
  parsing.

  The human clicks the trigger to open the dialog; that click starts their
  deliberation. The dialog is the approved mockup's master-detail layout: a
  leader context row (the human civ only — spec section 3), a left nav of the six
  Flavor-mode categories (Grand Strategy, Flavors, Next Research, Next Policy,
  Persona, Relationships) each with a one-line summary and a staged-edits badge,
  a right pane rendering the selected category from the OptionsReport, and a
  footer with the staged-changes summary, the single per-turn rationale, Keep
  Status Quo, and Submit. Submit fires the staged changes back as one
  HumanDecision; Keep Status Quo uses a two-click confirm when edits are staged.
  The dialog is hidable (Hide button or Esc) so the human can inspect the world
  without losing staged edits; the trigger stays until a decision is submitted,
  after which a small "auto-playing" chip reports the last decision.
-->
<Context Font="TwCenMT14" FontStyle="Base" Color="Beige" Color1="Black">

	<!-- ===== Single-select option row template (instantiated by the Lua) ===== -->
	<!-- One row per option in the Grand Strategy / Next Research / Next Policy
	     lists: icon, name (+ a "current" tag on the player's current selection),
	     and the same help text the LLM receives. The SelectionAnim highlight marks
	     the picked row; the Lua resizes the row and highlights to fit the wrapped
	     help text. Modeled on Community Patch's EventChoicePopup ItemInstance. -->
	<Instance Name="OptionInstance">
		<Box ID="Box" Anchor="L,T" Offset="0,0" Size="620,58" Color="255,255,255,0">
			<Button ID="Button" Anchor="L,T" Size="620,58" Offset="0,0" StateOffsetIncrement="0,0">
				<ShowOnMouseOver>
					<AlphaAnim ID="MouseOverAnim" Anchor="L,C" Size="620,58" Offset="0,0" Pause="0" Cycle="Bounce" Speed="1" AlphaStart="2" AlphaEnd="1">
						<Grid ID="MouseOverAnimHL" Size="620,58" Offset="0,0" Padding="0,0" Style="Grid9FrameTurnsHL"/>
					</AlphaAnim>
				</ShowOnMouseOver>
				<AlphaAnim ID="SelectionAnim" Hidden="1" Anchor="L,C" Size="620,58" Offset="0,0" Pause="0" Cycle="Bounce" Speed="1" AlphaStart="2" AlphaEnd="1">
					<Grid ID="SelectionAnimHL" Size="620,58" Offset="0,0" Padding="0,0" Style="Grid9FrameTurnsHL"/>
				</AlphaAnim>
				<Image ID="Icon" Anchor="L,T" Offset="6,7" Size="45,45" Hidden="1"/>
				<Label ID="Name" Anchor="L,T" Offset="58,7" WrapWidth="545" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
				<Label ID="Help" Anchor="L,T" Offset="58,32" WrapWidth="545" LeadingOffset="-4" Font="TwCenMT14" ColorSet="Beige_Black_Alpha"/>
			</Button>
		</Box>
	</Instance>

	<!-- ===== Plain text row (pane intros, notes, empty states) ===== -->
	<Instance Name="TextInstance">
		<Box ID="Box" Anchor="L,T" Offset="0,0" Size="620,24" Color="255,255,255,0">
			<Label ID="Text" Anchor="L,T" Offset="6,0" WrapWidth="600" LeadingOffset="-4" Font="TwCenMT14" ColorSet="Beige_Black_Alpha"/>
		</Box>
	</Instance>

	<!-- ===== Collapsible group header (flavor / persona sections) ===== -->
	<!-- The group's member rows are appended to the pane stack right after this
	     header; the Lua toggles their visibility (stacks skip hidden children)
	     and flips the +/- arrow. GroupMeta carries the member/changed count. -->
	<Instance Name="GroupInstance">
		<Box ID="Box" Anchor="L,T" Offset="0,0" Size="620,32" Color="255,255,255,0">
			<Button ID="Button" Anchor="L,T" Size="620,28" Offset="0,2" StateOffsetIncrement="0,0">
				<ShowOnMouseOver>
					<AlphaAnim ID="MouseOverAnim" Anchor="L,C" Size="620,28" Offset="0,0" Pause="0" Cycle="Bounce" Speed="1" AlphaStart="2" AlphaEnd="1">
						<Grid ID="MouseOverAnimHL" Size="620,28" Offset="0,0" Padding="0,0" Style="Grid9FrameTurnsHL"/>
					</AlphaAnim>
				</ShowOnMouseOver>
				<Label ID="Arrow" Anchor="L,C" Offset="8,0" Font="TwCenMT16" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
				<Label ID="GroupTitle" Anchor="L,C" Offset="28,0" Font="TwCenMT16" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
				<Label ID="GroupMeta" Anchor="R,C" Offset="10,0" Font="TwCenMT14" ColorSet="Beige_Black_Alpha"/>
			</Button>
		</Box>
	</Instance>

	<!-- ===== Slider row (flavors 0-100, persona 1-10, relationships -100..100) ===== -->
	<!-- Name + current->staged numbers, the option's descriptive text, then a
	     minus / slider / plus / reset line with semantic tick labels below. The
	     Lua positions the slider line under the wrapped description and sizes the
	     row to fit. -->
	<Instance Name="SliderInstance">
		<Box ID="Box" Anchor="L,T" Offset="0,0" Size="620,96" Color="255,255,255,0">
			<Label ID="Name" Anchor="L,T" Offset="6,4" Font="TwCenMT16" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
			<Label ID="Numbers" Anchor="R,T" Offset="34,6" Font="TwCenMT14" ColorSet="Beige_Black_Alpha"/>
			<Label ID="Desc" Anchor="L,T" Offset="6,26" WrapWidth="600" LeadingOffset="-4" Font="TwCenMT14" ColorSet="Beige_Black_Alpha"/>
			<GridButton ID="MinusButton" Anchor="L,T" Offset="6,50" Size="26,26" Style="SmallButton" StateOffsetIncrement="0,0">
				<Label Anchor="C,C" Offset="0,0" String="-" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
			</GridButton>
			<Slider ID="ValueSlider" Anchor="L,T" Offset="44,54" Length="420" Style="Slider" WheelSteps="10"/>
			<GridButton ID="PlusButton" Anchor="L,T" Offset="474,50" Size="26,26" Style="SmallButton" StateOffsetIncrement="0,0">
				<Label Anchor="C,C" Offset="0,0" String="+" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
			</GridButton>
			<GridButton ID="ResetButton" Anchor="L,T" Offset="508,50" Size="100,26" Style="SmallButton" StateOffsetIncrement="0,0" ToolTip="TXT_KEY_VD_HUMAN_RESET_TT">
				<Label Anchor="C,C" Offset="0,0" String="TXT_KEY_VD_HUMAN_RESET" Font="TwCenMT14" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
			</GridButton>
			<Label ID="Ticks" Anchor="L,T" Offset="44,78" Font="TwCenMT14" ColorSet="Beige_Black_Alpha"/>
		</Box>
	</Instance>

	<!-- ===== Relationship card header (one per met civ) ===== -->
	<!-- Leader portrait + names + the last-set note; the Public/Private slider
	     rows are appended right after as SliderInstances. Renders only met
	     leaders' names/portraits with the human's OWN stance values — recognition
	     aids, no foreign reasoning (spec section 3). -->
	<Instance Name="RelationInstance">
		<Box ID="Box" Anchor="L,T" Offset="0,0" Size="620,76" Color="255,255,255,0">
			<Image ID="Portrait" Anchor="L,T" Offset="6,6" Size="64,64" Hidden="1"/>
			<Label ID="Leader" Anchor="L,T" Offset="82,6" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
			<Label ID="Note" Anchor="L,T" Offset="82,32" WrapWidth="525" LeadingOffset="-4" Font="TwCenMT14" ColorSet="Beige_Black_Alpha"/>
		</Box>
	</Instance>

	<!-- ===== Left-nav category item (instantiated by the Lua) ===== -->
	<!-- Title (+ a staged-edits badge appended by the Lua) and a one-line
	     current-value summary. The SelectionAnim grid marks the active category. -->
	<Instance Name="NavInstance">
		<Box ID="Box" Anchor="L,T" Offset="0,0" Size="220,54" Color="255,255,255,0">
			<Button ID="Button" Anchor="L,T" Size="220,54" Offset="0,0" StateOffsetIncrement="0,0">
				<ShowOnMouseOver>
					<AlphaAnim ID="MouseOverAnim" Anchor="L,C" Size="220,54" Offset="0,0" Pause="0" Cycle="Bounce" Speed="1" AlphaStart="2" AlphaEnd="1">
						<Grid ID="MouseOverAnimHL" Size="220,54" Offset="0,0" Padding="0,0" Style="Grid9FrameTurnsHL"/>
					</AlphaAnim>
				</ShowOnMouseOver>
				<Grid ID="ActiveHL" Hidden="1" Size="220,54" Offset="0,0" Padding="0,0" Style="Grid9FrameTurnsHL"/>
				<Label ID="NavTitle" Anchor="L,T" Offset="10,6" TruncateWidth="200" Font="TwCenMT16" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
				<Label ID="NavSummary" Anchor="L,T" Offset="10,30" TruncateWidth="200" Font="TwCenMT14" ColorSet="Beige_Black_Alpha"/>
			</Button>
		</Box>
	</Instance>

	<!-- ===== Unique unit/building/improvement icon (leader context row) ===== -->
	<Instance Name="UniqueInstance">
		<Box ID="Box" Anchor="L,T" Offset="0,0" Size="45,45" Color="255,255,255,0">
			<Image ID="Icon" Anchor="L,T" Offset="0,0" Size="45,45"/>
		</Box>
	</Instance>

	<!-- ===== Corner widget: the native end-turn ("PLEASE WAIT") slot ===== -->
	<!-- Our own widget rather than a fork of Community Patch's ActionInfoPanel:
	     the native EndTurnButton lives in a separate UI context an addin cannot
	     reach and is already overridden by Vox Populi. Instead the trigger and
	     chip anchor to the bottom-right exactly like that button, and the Lua
	     copies the live native EndTurnButton size/offset (alignToEndTurnButton)
	     so the trigger lands in that slot above the minimap and effectively
	     overrides the "PLEASE WAIT" button. The static geometry below is the
	     fallback when the native button can't be reached; tune it in-game if the
	     placement needs nudging. The trigger and chip share the slot (only one is
	     shown at a time). -->
	<GridButton ID="TriggerButton" Hidden="1" Anchor="R,B" Offset="10,205" Size="320,46" Style="SmallButton" StateOffsetIncrement="0,0" ToolTip="TXT_KEY_VD_HUMAN_TRIGGER_TT">
		<!-- Match the wide native "PLEASE WAIT" slot so the trigger fully covers
		     it even when the live EndTurnButton lookup is unavailable. -->
		<Label Anchor="C,C" Offset="0,0" TruncateWidth="300" String="TXT_KEY_VD_HUMAN_TRIGGER_TITLE" Font="TwCenMT24" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
	</GridButton>
	<!-- Auto-playing chip: shown in the same slot once a decision is submitted;
	     reports the last decision for session-state legibility (spec section 6). -->
	<Box ID="AutoplayChip" Hidden="1" Anchor="R,B" Offset="10,205" Size="320,38" Color="0,0,0,150" ConsumeMouse="0">
		<Label Anchor="C,C" Offset="0,0" WrapWidth="312" Font="TwCenMT14" ColorSet="Beige_Black_Alpha" FontStyle="Shadow" ID="AutoplayChipLabel"/>
	</Box>

	<!-- ===== Decision dialog (hidden until the trigger is clicked) ===== -->
	<!-- The dim backdrop and the grid are toggled together by the Lua (they are
	     not wrapped in a sized container so each still anchors to the screen). -->
	<Box ID="DialogDim" Hidden="1" Style="BGBlock_ClearTopBar"/>
	<Grid Hidden="1" Size="1000,744" ID="MainGrid" Anchor="C,C" Offset="0,0" Padding="0,0" Style="Grid9DetailFive140" ConsumeMouse="1">
		<!-- Side treatments + title, matching the native popup framing. -->
		<Box Style="MenuLeftSideTreatment"/>
		<Box Style="MenuRightSideTreatment"/>
		<Label Style="MenuTitleCaption" TruncateWidth="660" String="TXT_KEY_VD_HUMAN_TITLE" ID="TitleLabel"/>

		<!-- Hide: close the dialog to look around. The game stays paused, staged
		     edits and the typed rationale are kept, and the trigger reopens it. -->
		<GridButton ID="HideButton" Anchor="R,T" Offset="20,16" Size="92,28" Style="SmallButton" StateOffsetIncrement="0,0" ToolTip="TXT_KEY_VD_HUMAN_HIDE_TT">
			<Label Anchor="C,C" Offset="0,0" String="TXT_KEY_VD_HUMAN_HIDE" Font="TwCenMT14" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
		</GridButton>

		<!-- Leader context row: the human civ's leader portrait, trait, and unique
		     components — the same data the EUI leader-choose dialog shows at
		     pre-game, read from the game database. Only the human's own civ. -->
		<Image ID="LeaderPortrait" Anchor="L,T" Offset="30,56" Size="64,64" Hidden="1"/>
		<Label ID="LeaderName" Anchor="L,T" Offset="104,58" TruncateWidth="620" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
		<Label ID="LeaderTraitDesc" Anchor="L,T" Offset="104,84" WrapWidth="620" LeadingOffset="-5" Font="TwCenMT14" ColorSet="Beige_Black_Alpha"/>
		<Stack ID="UniquesStack" Anchor="R,T" Offset="30,62" StackGrowth="Right" Padding="4"/>

		<!-- Decorative rules separate the header, chooser, staged summary, and
		     rationale/action areas while keeping the native popup treatment. -->
		<Box Anchor="L,T" Offset="30,140" Size="940,1" Color="204,170,90,180"/>
		<Box Anchor="L,T" Offset="30,141" Size="940,1" Color="0,0,0,150"/>
		<Box Anchor="L,T" Offset="260,156" Size="1,394" Color="204,170,90,110"/>
		<Box Anchor="L,T" Offset="261,156" Size="1,394" Color="0,0,0,120"/>

		<!-- Left nav: the six Flavor-mode categories. -->
		<Stack ID="NavStack" Anchor="L,T" Offset="30,156" Padding="4" StackGrowth="Bottom"/>

		<!-- Right pane: the selected category, rebuilt on category switch. -->
		<Label ID="CategoryHeader" Anchor="L,T" Offset="280,154" TruncateWidth="670" Font="TwCenMT20" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
		<ScrollPanel Anchor="L,T" Offset="280,184" Size="690,370" AutoScrollBar="1" Vertical="1" ID="PaneScroll">
			<ScrollBar ID="ScrollBar" Style="VertSlider" Length="332" Offset="2,18" Anchor="R,T" AnchorSide="O,I"/>
			<UpButton ID="ScrollBarU" Offset="2,0" Style="ScrollBarUp" Anchor="R,T" AnchorSide="O,I"/>
			<DownButton ID="ScrollBarD" Offset="2,0" Style="ScrollBarDown" Anchor="R,B" AnchorSide="O,I"/>
			<Stack Anchor="L,T" Offset="0,0" Padding="4" StackGrowth="Bottom" ID="PaneStack"/>
		</ScrollPanel>

		<Box Anchor="L,T" Offset="30,566" Size="940,1" Color="204,170,90,150"/>
		<Box Anchor="L,T" Offset="30,567" Size="940,1" Color="0,0,0,140"/>

		<!-- Staged-changes summary: a wrapping multi-line list of every staged
		     change (undo happens where each change was made — sliders have Reset,
		     lists unstage by re-picking the current option). -->
		<Label ID="StagedLabel" Anchor="L,T" Offset="30,574" WrapWidth="940" LeadingOffset="-4" Font="TwCenMT14" ColorSet="Beige_Black_Alpha"/>

		<Box Anchor="L,T" Offset="30,606" Size="940,1" Color="204,170,90,120"/>
		<Box Anchor="L,T" Offset="30,607" Size="940,1" Color="0,0,0,130"/>

		<!-- Rationale prompt + single free-text field (one rationale per turn, spec section 2). -->
		<Label Anchor="L,T" Offset="30,614" WrapWidth="940" Font="TwCenMT16" ColorSet="Beige_Black_Alpha" FontStyle="Shadow" String="TXT_KEY_VD_HUMAN_RATIONALE_PROMPT" ID="RationalePrompt"/>
		<Box Anchor="L,T" Offset="30,638" Size="940,30" Color="0,0,0,140">
			<EditBox CallOnChar="1" Anchor="L,C" Offset="8,0" Size="924,24" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" ID="RationaleBox" MaxLength="300"/>
		</Box>

		<!-- Actions. Keep Status Quo submits a status-quo decision (two-click
		     confirm when changes are staged — the Lua swaps the label); Submit
		     fires the staged changes once ≥1 change and a rationale are present. -->
		<GridButton Anchor="L,B" Style="SmallButton" Size="260,32" Offset="30,22" StateOffsetIncrement="0,0" ToolTip="TXT_KEY_VD_HUMAN_KEEP_STATUS_QUO_TT" ID="StatusQuoButton">
			<Label Anchor="C,C" Offset="0,0" String="TXT_KEY_VD_HUMAN_KEEP_STATUS_QUO" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" FontStyle="Shadow" ID="StatusQuoLabel"/>
		</GridButton>
		<GridButton Anchor="R,B" Style="SmallButton" Size="200,32" Offset="30,22" StateOffsetIncrement="0,0" ToolTip="TXT_KEY_VD_HUMAN_SUBMIT_TT" ID="SubmitButton">
			<Label Anchor="C,C" Offset="0,0" String="TXT_KEY_VD_HUMAN_SUBMIT" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
		</GridButton>

		<!-- Submission-accepted overlay (shown briefly after a decision is sent). -->
		<Box ID="AcceptedOverlay" Hidden="1" Anchor="C,C" Offset="0,0" Size="1000,744" Color="0,0,0,210" ConsumeMouse="1">
			<Label Anchor="C,C" Offset="0,-16" Font="TwCenMT24" ColorSet="Beige_Black_Alpha" FontStyle="Shadow" String="TXT_KEY_VD_HUMAN_ACCEPTED" ID="AcceptedTitle"/>
			<Label Anchor="C,C" Offset="0,22" WrapWidth="700" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" FontStyle="Shadow" String="TXT_KEY_VD_HUMAN_ACCEPTED_SUB" ID="AcceptedSub"/>
		</Box>
	</Grid>
</Context>
