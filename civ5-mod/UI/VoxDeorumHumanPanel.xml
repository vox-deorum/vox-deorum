<?xml version="1.0" encoding="utf-8"?>
<!--
  Vox Deorum human-control decision panel — stage 5 (keep-status-quo only),
  revised to the approved mockup's trigger-button + hidable-dialog model.

  The same-named VoxDeorumHumanPanel.lua auto-binds to this context. The whole
  context is hidden on load. When the strategist fires
  LuaEvents.VoxDeorumHumanDecision(playerID, turn, optionsJson) the corner
  widget's trigger button appears in the bottom-right action slot — standing in
  for the native "PLEASE WAIT" button — instead of the dialog popping up. The
  human clicks the trigger to open the dialog; that click starts their
  deliberation (the later-plans decision timer). The dialog is hidable (Hide
  button or Esc) so the human can inspect the world without losing the typed
  rationale; the trigger stays until a decision is submitted, after which a
  small "auto-playing" chip reports the last decision. Option categories
  (Submit) arrive in stages 6-7.
-->
<Context Font="TwCenMT14" FontStyle="Base" Color="Beige" Color1="Black">

	<!-- ===== Corner widget: the native end-turn ("PLEASE WAIT") slot ===== -->
	<!-- Our own widget rather than a fork of Community Patch's ActionInfoPanel:
	     the native EndTurnButton lives in a separate UI context an addin cannot
	     reach and is already overridden by Vox Populi. Instead the trigger and
	     chip anchor to the bottom-right exactly like that button, and the Lua
	     copies the live native EndTurnButton size/offset (alignToEndTurnButton)
	     so the trigger lands in that slot above the minimap and effectively
	     overrides the "PLEASE WAIT" button. The static geometry below is the
	     fallback when the native button can't be reached; tune it in-game if the
	     placement needs nudging. The trigger and chip share the slot (only one is
	     shown at a time). -->
	<!-- Pulsing-by-presence decision trigger: clicking it opens the dialog and
	     starts the human's deliberation. Visible while a decision is pending;
	     hidden once a decision is submitted. One short line of text, matching the
	     native button it stands in for. -->
	<GridButton ID="TriggerButton" Hidden="1" Anchor="R,B" Offset="10,205" Size="204,46" Style="SmallButton" StateOffsetIncrement="0,0" ToolTip="TXT_KEY_VD_HUMAN_TRIGGER_TT">
		<Label Anchor="C,C" Offset="0,0" TruncateWidth="190" String="TXT_KEY_VD_HUMAN_TRIGGER_TITLE" Font="TwCenMT20" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
	</GridButton>
	<!-- Auto-playing chip: shown in the same slot once a decision is submitted;
	     reports the last decision for session-state legibility (spec section 6). -->
	<Box ID="AutoplayChip" Hidden="1" Anchor="R,B" Offset="10,205" Size="204,38" Color="0,0,0,150" ConsumeMouse="0">
		<Label Anchor="C,C" Offset="0,0" WrapWidth="196" Font="TwCenMT14" ColorSet="Beige_Black_Alpha" FontStyle="Shadow" ID="AutoplayChipLabel"/>
	</Box>

	<!-- ===== Decision dialog (hidden until the trigger is clicked) ===== -->
	<!-- The dim backdrop and the grid are toggled together by the Lua (they are
	     not wrapped in a sized container so each still anchors to the screen). -->
	<Box ID="DialogDim" Hidden="1" Style="BGBlock_ClearTopBar"/>
	<Grid Hidden="1" Size="560,360" ID="MainGrid" Anchor="C,C" Offset="0,0" Padding="0,0" Style="Grid9DetailFive140" ConsumeMouse="1">
		<!-- Side treatments + title, matching the native popup framing. -->
		<Box Style="MenuLeftSideTreatment"/>
		<Box Style="MenuRightSideTreatment"/>
		<Label Style="MenuTitleCaption" TruncateWidth="440" String="TXT_KEY_VD_HUMAN_TITLE" ID="TitleLabel"/>

		<!-- Hide: close the dialog to look around. The game stays paused, the
		     typed rationale is kept, and the trigger button reopens it. -->
		<GridButton ID="HideButton" Anchor="R,T" Offset="20,16" Size="92,28" Style="SmallButton" StateOffsetIncrement="0,0" ToolTip="TXT_KEY_VD_HUMAN_HIDE_TT">
			<Label Anchor="C,C" Offset="0,0" String="TXT_KEY_VD_HUMAN_HIDE" Font="TwCenMT14" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
		</GridButton>

		<!-- Status line: whose turn / that a decision is pending (spec section 6). -->
		<Label Anchor="L,T" Offset="30,52" WrapWidth="500" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" FontStyle="Shadow" ID="StatusLabel"/>

		<!-- Rationale prompt + single free-text field (one rationale per turn, spec section 2). -->
		<Label Anchor="L,T" Offset="30,96" WrapWidth="500" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" FontStyle="Shadow" String="TXT_KEY_VD_HUMAN_RATIONALE_PROMPT" ID="RationalePrompt"/>
		<Box Anchor="L,T" Offset="30,150" Size="500,40" Color="0,0,0,140">
			<EditBox CallOnChar="1" Anchor="L,C" Offset="8,0" Size="484,28" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" ID="RationaleBox" MaxLength="200"/>
		</Box>

		<!-- Actions. Keep Status Quo submits a status-quo decision; Submit is shown
		     but stays disabled in stage 5 (no option categories to stage yet). -->
		<GridButton Anchor="L,B" Style="SmallButton" Size="170,32" Offset="30,40" StateOffsetIncrement="0,0" ToolTip="TXT_KEY_VD_HUMAN_KEEP_STATUS_QUO_TT" ID="StatusQuoButton">
			<Label Anchor="C,C" Offset="0,0" String="TXT_KEY_VD_HUMAN_KEEP_STATUS_QUO" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
		</GridButton>
		<GridButton Anchor="R,B" Style="SmallButton" Size="170,32" Offset="30,40" StateOffsetIncrement="0,0" ToolTip="TXT_KEY_VD_HUMAN_SUBMIT_TT" ID="SubmitButton">
			<Label Anchor="C,C" Offset="0,0" String="TXT_KEY_VD_HUMAN_SUBMIT" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
		</GridButton>

		<!-- Submission-accepted overlay (shown briefly after a decision is sent). -->
		<Box ID="AcceptedOverlay" Hidden="1" Anchor="C,C" Offset="0,0" Size="560,360" Color="0,0,0,210" ConsumeMouse="1">
			<Label Anchor="C,C" Offset="0,-16" Font="TwCenMT24" ColorSet="Beige_Black_Alpha" FontStyle="Shadow" String="TXT_KEY_VD_HUMAN_ACCEPTED" ID="AcceptedTitle"/>
			<Label Anchor="C,C" Offset="0,22" WrapWidth="460" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" FontStyle="Shadow" String="TXT_KEY_VD_HUMAN_ACCEPTED_SUB" ID="AcceptedSub"/>
		</Box>
	</Grid>
</Context>
