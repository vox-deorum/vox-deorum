<?xml version="1.0" encoding="utf-8"?>
<!--
  Vox Deorum human-control trigger widget.

  This context stays tiny and non-modal: it only owns the bottom-right decision
  trigger / autoplay chip. The full decision panel lives in VoxDeorumHumanPanel
  and hides its entire context when minimized, allowing ordinary Civ/VP popups to
  appear while the human looks around.
-->
<Context Font="TwCenMT14" FontStyle="Base" Color="Beige" Color1="Black">
	<!-- Native end-turn ("PLEASE WAIT") slot replacement. The Lua copies the
	     live EndTurnButton geometry when possible; this is only the fallback. -->
	<GridButton ID="TriggerButton" Hidden="1" Anchor="R,B" Offset="16,200" Size="320,36" Style="SmallButton" StateOffsetIncrement="0,0" ToolTip="TXT_KEY_VD_HUMAN_TRIGGER_TT">
		<Label Anchor="C,C" Offset="0,0" TruncateWidth="300" String="TXT_KEY_VD_HUMAN_TRIGGER_TITLE" Font="TwCenMT24" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"/>
	</GridButton>

	<!-- Shown in the same slot after a decision is accepted. -->
	<Box ID="AutoplayChip" Hidden="1" Anchor="R,B" Offset="16,200" Size="320,36" Color="0,0,0,150" ConsumeMouse="0">
		<Label Anchor="C,C" Offset="0,0" WrapWidth="312" Font="TwCenMT14" ColorSet="Beige_Black_Alpha" FontStyle="Shadow" ID="AutoplayChipLabel"/>
	</Box>
</Context>
