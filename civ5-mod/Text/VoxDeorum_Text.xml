		<Row Tag="TXT_KEY_VD_HUMAN_REL_NOTE_NONE">
			<Text>[COLOR_GREY]No stance set yet - both values neutral.[ENDCOLOR]</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_REL_EMPTY">
			<Text>You have not met any other civilizations yet.</Text>
		</Row>

		<!-- Footer: the wrapping staged-changes summary. -->
		<Row Tag="TXT_KEY_VD_HUMAN_STAGED_NONE">
			<Text>[COLOR_GREY]No changes staged yet - submitting now would keep the status quo.[ENDCOLOR]</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_STAGED_SOME">
			<Text>Staged changes ({1_Num}): {2_Str}</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_STAGED_MORE">
			<Text>(+{1_Num} more)</Text>
		</Row>

		<!-- Action buttons. -->
		<Row Tag="TXT_KEY_VD_HUMAN_KEEP_STATUS_QUO">
			<Text>Keep Status Quo</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_KEEP_STATUS_QUO_TT">
			<Text>Keep everything as it is. This is recorded as a real decision with your rationale - last turn's is filled in by default; edit it if you like. If you have staged changes, a second click confirms discarding them.</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_KEEP_SQ_CONFIRM">
			<Text>Discard {1_Num} changes?</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_SUBMIT">
			<Text>Submit Decision</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_SUBMIT_TT">
			<Text>Submit your staged changes with your rationale. Enabled once at least one change is staged and a rationale is typed.</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_ACCEPTED">
			<Text>Decision submitted</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_ACCEPTED_SUB">
			<Text>Your civilization resumes auto-play.</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_ACCEPTED_SUB_DECISION">
