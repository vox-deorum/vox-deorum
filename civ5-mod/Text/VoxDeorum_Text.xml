<?xml version="1.0" encoding="utf-8"?>
<GameData>
	<Language_en_US>
		<!-- Human-control decision panel (stage 5). Plain language, no identifiers. -->
		<Row Tag="TXT_KEY_VD_HUMAN_TITLE">
			<Text>Make Your Decisions</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_STATUS_PENDING">
			<Text>Turn {1_Num} - the game is paused, waiting on your decision.</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_RATIONALE_PROMPT">
			<Text>Why are you making this decision? One rationale covers the whole turn.</Text>
		</Row>
