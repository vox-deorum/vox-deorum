<?xml version="1.0" encoding="utf-8"?>
<GameData>
	<Language_en_US>
		<!-- Human-control decision panel (stages 5-7). Plain language, no identifiers. -->
		<Row Tag="TXT_KEY_VD_HUMAN_TITLE">
			<Text>Make Your Decisions</Text>
		</Row>
		<!-- Corner trigger button: fills the native end-turn ("PLEASE WAIT")
		     button slot above the minimap, overriding it entirely. All-caps to
		     match that button's style. Opens the dialog and starts the human's
		     deliberation. Shown while a decision is pending. -->
		<Row Tag="TXT_KEY_VD_HUMAN_TRIGGER_TITLE">
			<Text>MAKE STRATEGIC DECISION</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_TRIGGER_TT">
			<Text>A strategic decision is due. Click to open your decision panel - this starts your deliberation. The game stays paused until you submit.</Text>
		</Row>
		<!-- Auto-playing chip: shown between decisions, reporting the last one. -->
		<Row Tag="TXT_KEY_VD_HUMAN_AUTOPLAY_CHIP_DECISION">
			<Text>Auto-playing - last decision T{1_Num}: {2_Str}</Text>
		</Row>
		<!-- Hide button in the dialog title bar. -->
		<Row Tag="TXT_KEY_VD_HUMAN_HIDE">
			<Text>Hide</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_HIDE_TT">
			<Text>Hide this panel to look around. The game stays paused, your staged changes and typed rationale are kept, and the button above the minimap brings it back.</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_RATIONALE_PROMPT">
			<Text>Why are you making this decision? One rationale covers the whole turn.</Text>
		</Row>

		<!-- The six category names: left-nav titles, pane headers, and the
		     prefixes used in change summaries. -->
		<Row Tag="TXT_KEY_VD_HUMAN_CAT_STRATEGY">
			<Text>Grand Strategy</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_CAT_FLAVORS">
			<Text>Flavors</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_CAT_RESEARCH">
			<Text>Next Research</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_CAT_POLICY">
			<Text>Next Policy</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_CAT_PERSONA">
			<Text>Persona</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_CAT_RELATIONS">
			<Text>Relationships</Text>
		</Row>

		<!-- Pane intros. Option help text itself comes from the OptionsReport -
		     the same descriptive text the LLM strategists receive. -->
		<Row Tag="TXT_KEY_VD_HUMAN_STRATEGY_INTRO">
			<Text>Your civilization's overall direction - the in-game AI weighs its choices toward this goal.</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_FLAVORS_INTRO">
			<Text>Tune how the in-game AI runs your empire: 0 forbids, 50 is balanced, 100 is an emergency focus. Change only what you mean to.</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_RESEARCH_INTRO">
			<Text>Pick what your scientists research next - the in-game AI handles the rest.</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_POLICY_INTRO">
			<Text>Choose the next social policy to adopt. A new branch commits to its theme; continuing one deepens it.</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_PERSONA_INTRO">
			<Text>How your civilization behaves diplomatically - how bold, loyal, forgiving, or competitive the AI acts. Values run 1 (low) to 10 (high).</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_RELATIONS_INTRO">
			<Text>Your stance toward each civilization you have met. Public is shown openly; Private steers how your empire treats them. Range -100 to +100.</Text>
		</Row>

		<!-- Shared option-list furniture. -->
		<Row Tag="TXT_KEY_VD_HUMAN_CURRENT_TAG">
			<Text>[COLOR_POSITIVE_TEXT](current)[ENDCOLOR]</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_EARLIER_RATIONALE">
			<Text>[COLOR_GREY]Your earlier rationale: "{1_Str}"[ENDCOLOR]</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_PANE_EMPTY">
			<Text>No options are available in this category right now. You can keep the status quo.</Text>
		</Row>
		<Row Tag="TXT_KEY_VD_HUMAN_RESEARCH_EMPTY">
			<Text>No research choices are available right now. You can keep the status quo.</Text>
		</Row>

		<!-- Collapsible groups (panel-only readability; the LLM sees flat lists). -->
		<Row Tag="TXT_KEY_VD_HUMAN_FLAVOR_GROUP_EXPANSION">
