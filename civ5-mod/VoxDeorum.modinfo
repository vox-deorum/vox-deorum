  <EntryPoints>
    <EntryPoint type="MapScript" file="Mapscripts/Vox_Deorum.lua">
      <Name>Vox_Deorum</Name>
      <Description>Communitas rewrite by tu_79 and azum4roll - fixed parameters for Vox Deorum research</Description>
