      <Name>VoxDeorumTest</Name>
      <Description>Test listener for Vox Deorum observer API events</Description>
    </EntryPoint>
    <EntryPoint type="InGameUIAddin" file="UI/VoxDeorumHumanPanel.xml">
      <Name>VoxDeorumHumanPanel</Name>
      <Description>Human-control decision panel (dormant until a decision is presented)</Description>
    </EntryPoint>
    <EntryPoint type="InGameUIAddin" file="UI/VoxDeorumHumanTrigger.xml">
      <Name>VoxDeorumHumanTrigger</Name>
      <Description>Human-control trigger widget for reopening the decision panel</Description>
    </EntryPoint>
  </EntryPoints>
