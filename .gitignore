.DS_STORE
coverage
node_modules
dist
/node
/temp
/logs
.tmp/
.env
nul

# Oracle telemetry output (also ignored in vox-agents/.gitignore; covered here
# in case a run writes it at the repo root)
/telemetry/

# DLL cache directory
scripts/.dll-cache
/*.bat

# Local junction so Claude Code discovers skills under .agents/skills/.
# Source of truth is .agents/skills/; this link is machine-local (recreate with
# `mklink /J .claude\skills .agents\skills`).
.claude/skills/
