    "dompurify": "^3.3.1",
    "marked": "^17.0.1",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.3",
    "sse.js": "^2.7.2",
    "virtua": "^0.48.2",
    "vue": "^3.5.25",
    "vue-json-pretty": "^2.6.0",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.3",
    "@types/jsdom": "^27.0.0",
