    "test:watch": "cross-env USE_MOCK=true vitest",
    "test:coverage": "cross-env USE_MOCK=true vitest run --coverage",
    "test:unit": "cross-env USE_MOCK=true vitest run",
    "build-only": "vite build",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
