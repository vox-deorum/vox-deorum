{
  "name": "vox-agents",
  "version": "1.0.0",
  "description": "LLM-powered strategic AI agents for Civilization V that provide high-level decision making and strategy planning through the Vox Deorum system.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "rimraf dist && node ../node_modules/typescript/bin/tsc && cd ui && npm run build",
    "dev": "tsx watch --import ./src/instrumentation.ts src/index.ts",
    "start": "npm run build && npm run start:dist --",
    "start:dist": "node --inspect --import ./dist/instrumentation.js --experimental-loader=@opentelemetry/instrumentation/hook.mjs dist/index.js",
    "strategist": "npm run build && npm run strategist:dist --",
    "strategist:dist": "node --inspect --import ./dist/instrumentation.js --experimental-loader=@opentelemetry/instrumentation/hook.mjs dist/strategist/console.js",
    "telepathist": "npm run build && npm run telepathist:dist --",
    "telepathist:dist": "node --inspect --import ./dist/instrumentation.js --experimental-loader=@opentelemetry/instrumentation/hook.mjs dist/telepathist/console.js",
    "oracle": "npm run build && npm run oracle:dist --",
    "oracle:dist": "node --inspect --import ./dist/instrumentation.js --experimental-loader=@opentelemetry/instrumentation/hook.mjs dist/oracle/console.js",
    "test": "cross-env USE_MOCK=true vitest run",
    "test:mock": "cross-env USE_MOCK=true vitest run",
    "test:real": "cross-env USE_MOCK=false vitest run --passWithNoTests",
    "test:watch": "cross-env USE_MOCK=true vitest",
    "test:ui": "cross-env USE_MOCK=true vitest --ui",
    "test:coverage": "cross-env USE_MOCK=true vitest run --coverage",
    "test:game": "cross-env TEST_TIER=live/game vitest run",
    "test:obs": "cross-env TEST_TIER=live/obs vitest run",
    "archivist": "npm run build && npm run archivist:dist --",
    "archivist:dist": "node --import ./dist/instrumentation.js dist/archivist/console.js",
    "narrator": "npm run build && npm run narrator:dist --",
    "narrator:dist": "node --inspect --import ./dist/instrumentation.js --experimental-loader=@opentelemetry/instrumentation/hook.mjs dist/narrators/console.js",
    "type-check": "tsc --noEmit",
    "docs": "typedoc"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "open": "^11.0.0",
    "openai": "^6.35.0",
    "uuid": "^13.0.0"
  }
}
